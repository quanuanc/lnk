{
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "proxy": "socks5h://127.0.0.1:6153",
  "edit_predictions": {
    "mode": "subtle",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
      "default_model": "gpt-5.2/high",
    },
  },
  "base_keymap": "VSCode",
  "git_panel": {
    "dock": "left",
    "sort_by_path": true,
  },
  "ssh_connections": [
    {
      "host": "echo",
      "args": [],
      "projects": [],
    },
  ],
  "agent": {
    "dock": "right",
    "default_profile": "write",
    "default_model": {
      "effort": "high",
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
    },
    "model_parameters": [],
  },
  "auto_install_extensions": {
    "beancount": false,
    "nix": false,
  },
  "autosave": "on_focus_change",
  "cursor_blink": false,
  "format_on_save": "off",
  "lsp": {},
  "relative_line_numbers": "enabled",
  "tab_size": 2,
  "terminal": {
    "copy_on_select": true,
    "option_as_meta": true,
    "line_height": "standard",
    "detect_venv": "off",
  },
  "vim": {
    "use_smartcase_find": true,
    "use_system_clipboard": "always",
  },
  "vim_mode": true,
  "project_panel": {
    "dock": "left",
    "auto_reveal_entries": false,
  },
}
